[Unit]
Description=autoLV VWorld Proxy (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/autolv-vworld-proxy
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/autolv-vworld-proxy/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
